            },
            "properties": [
              {
                "id": "displayName",
                "value": "Time"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tokens"
              },
              {
                "id": "unit",
                "value": "short"
